theme = Rose Pine
font-family = JetBrains Mono
font-style = Bold
font-thicken = true

mouse-hide-while-typing = true
window-decoration = true

macos-option-as-alt = true

scrollback-limit = 500000000

custom-shader = /Users/pablomarelli/.config/ghostty/shaders/cursor_smear.glsl
