set -g mouse on

# Reload tmux conf
unbind r
bind r source-file ~/.config/tmux/tmux.conf

# Set prefix
unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

#Disable exit-empty
set -s exit-empty off

# Color settings
# Ghostty
# Add these lines to your tmux config for proper truecolor support:
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256col*:Tc"
set -ga terminal-overrides ",xterm-256color:RGB"

# Start windows and panes at 1, not 0
set -g base-index 1
set -g pane-base-index 1
set-window-option -g pane-base-index 1
set-option -g renumber-windows on
set -g detach-on-destroy off     # don't exit from tmux when closing a session
set -g escape-time 0             # zero-out escape time delay
set -g history-limit 100000     # increase history size (from 2,000)
set -g status-position top       # macOS / darwin style

# Unbind the default copy mode trigger
unbind C-S-Space

# Set new copy mode trigger (Ctrl-s Space v)
# bind v copy-mode
bind -n M-v copy-mode

# Switch to last session with Alt+. (period)
bind -n 'M-.' switch-client -l

# Switch to last window with Alt+, (comma)
bind -n 'M-,' last-window

# Resize pane bindings (prefix + arrow keys)
bind Up resize-pane -U 5
bind Down resize-pane -D 5
bind Left resize-pane -L 5
bind Right resize-pane -R 5

# Plugins
set -g @plugin 'tmux-plugins/tpm' # Tmux plugin manager
# set -g @plugin 'jimeh/tmuxifier'

set -g @plugin 'tmux-plugins/tmux-sensible' # Sensible adds keybindings
set -g @plugin 'tmux-plugins/tmux-yank' # When using vim mode you can yank into clipboard

# Adds seamless nvim and tmux panes navigation
set -g @plugin 'christoomey/vim-tmux-navigator'

# Replace the default session picker with Television's sesh channel.
# This keeps prefix + o as the session picker while avoiding sessionx.
bind o display-popup -E -w 80% -h 70% -d '#{pane_current_path}' -T 'Sesh' tv sesh

# Unbind default session picker (using tv sesh on prefix + o instead)
unbind s

# tmux-jump - easymotion-like jumps
set -g @plugin 'schasse/tmux-jump'
set -g @jump-key 's'

# tmux-floax
set -g @plugin 'omerxx/tmux-floax'

# tmux-fingers - vimium-like hints for tmux
# set -g @plugin 'Morantron/tmux-fingers'
# # Key bindings (override default session picker - using tv sesh instead)
# set -g @fingers-jump-key s      # prefix + s → jump to match (move cursor)
# set -g @fingers-key S           # prefix + S → copy match
# # Custom patterns
# set -g @fingers-pattern-0 '[A-Za-z0-9_.+-]+@([A-Za-z0-9-]+\\.)+[A-Za-z]{2,}'  # emails
# set -g @fingers-pattern-1 '[a-f0-9]{2}(:[a-f0-9]{2}){5}'    # MAC addresses  
# set -g @fingers-pattern-2 '[a-f0-9]{12,64}'                  # Docker container IDs

# tmux-thumbs
# set -g @plugin 'fcsonline/tmux-thumbs'
# set -g @thumbs-key 's'
# set -g @thumbs-command 'echo -n {} | pbcopy'

# Themes - PowerKit (replaces tmux-tokyo-night)
set -g @plugin 'fabioluciano/tmux-powerkit'

# PowerKit configuration
{{- if eq .chezmoi.os "darwin" }}
set -g @powerkit_theme "monokai"
set -g @powerkit_theme_variant "dark"
{{- else }}
set -g @powerkit_theme "tokyo-night"
set -g @powerkit_theme_variant "storm"
{{- end }}
set -g @powerkit_plugins "cpu, memory, temperature, vpn, cloud, kubernetes"
set -g @powerkit_separator_style "normal"
# Different style for edge separators
set -g @powerkit_edge_separator_style "flame"
set -g @powerkit_left_separator ''
set -g @powerkit_right_separator ''

# Single line layout (default)
set -g @powerkit_bar_layout "single"
# Double line layout (session on top, plugins on bottom)
# set -g @powerkit_bar_layout "double"

# Disable PowerKit keybindings and conflict warnings
set -g @powerkit_keybinding_conflict_action "ignore"
set -g @powerkit_show_options_key ""
set -g @powerkit_show_keybindings_key ""
set -g @powerkit_theme_selector_key ""
set -g @powerkit_cache_clear_key ""
set -g @powerkit_log_viewer_key ""
set -g @powerkit_reload_config_key ""

# Enable focus events
set-option -g focus-events on

# Set background and foreground for the focused pane
# set-hook -g pane-focus-in 'select-pane -P "fg=white"'

# Set a slightly brighter background for unfocused panes
# set-hook -g pane-focus-out 'select-pane -P "bg=#2F2D3E,fg=default"'

# Navi
bind-key -T prefix C-g split-window \
  "$SHELL --login -i -c 'navi --print | head -n 1 | tmux load-buffer -b tmp - ; tmux paste-buffer -p -t {last} -b tmp -d'"

# Use xclip to copy and paste with the system clipboard
bind C-c run "tmux save-buffer - | xclip -i -sel clip"
bind C-v run "tmux set-buffer $(xclip -o -sel clip); tmux paste-buffer"

# set vi-mode
set-window-option -g mode-keys vi # Vi mode lets you navigate the strrout with vim keybinds. prefix + {

# keybindings bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel

bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

# Session restoring and reopening
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# resurrect-strategy-nvim
# for neovim
set -g @continuum-restore 'on'
set -g @continuum-save-interval '30'
set -g @resurrect-strategy-nvim 'session'
set -g @resurrect-capture-pane-contents 'on'
# set -g @resurrect-processes 'false'

run '~/.config/tmux/plugins/tpm/tpm'

# Floax rebinds C-M-d/C-M-u when opening the popup. Wrap the launcher and
# immediately unbind those two keys so app shortcuts can use them.
unbind p
bind p run-shell "~/.config/tmux/plugins/tmux-floax/scripts/floax.sh; tmux unbind -n C-M-d; tmux unbind -n C-M-u"
unbind -n C-M-d
unbind -n C-M-u

