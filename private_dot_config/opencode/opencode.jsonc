{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["AGENTS.md", "AGENTS.local.md"],

  // Personal overrides only. Gentle AI managed SDD agents, commands,
  // skills, context7, and engram MCP stay in opencode.json.
  // "provider": {
  //   "anthropic": {
  //     "whitelist": ["claude-opus-4-6", "claude-sonnet-4-6"]
  //   },
  //   "openai": {
  //     "whitelist": ["gpt-5.3-codex", "gpt-5.4"]
  //   }
  // },
  "permission": {
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },

  "mode": {
    "build": {},
    "plan": {}
  },

  // "model": "openai/gpt-5.3-codex",
  // "model": "anthropic/claude-opus-4-6",
  "model": "openai/gpt-5.5",
  "small_model": "anthropic/claude-sonnet-4-6",

  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    },
    "atlassian": {
      "type": "local",
      "command": ["uvx", "--python", "3.12", "mcp-atlassian"],
      "enabled": true,
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}"
      }
    }
  }
}
