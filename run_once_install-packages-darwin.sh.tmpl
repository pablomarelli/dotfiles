{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# macOS bootstrap - runs once on first chezmoi apply
set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

command_exists() { command -v "$1" >/dev/null 2>&1; }

echo "==> macOS bootstrap"

# ── Homebrew ──────────────────────────────────────────────────────────────────
if ! command_exists brew; then
  echo -e "${YELLOW}→${NC} Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  # Add brew to PATH for the rest of this script (Apple Silicon)
  eval "$(/opt/homebrew/bin/brew shellenv)" 2>/dev/null || true
else
  echo -e "${GREEN}✓${NC} Homebrew already installed"
fi

# ── Homebrew packages ─────────────────────────────────────────────────────────
# Only things that can't or shouldn't be managed by mise:
#   - zsh, git, gcc: system-level tools, better via brew on macOS
#   - ghostty, alacritty: GUI apps / terminal emulators, macOS-only
BREW_PKGS=(
  zsh           # shell
  git           # version control
  gcc           # C compiler (needed by some cargo/python builds)
  git-crypt     # git encryption
  dark-notify   # macOS appearance watcher for Neovim
  diffnav       # diff navigator (dlvhdr/formulae)
  tailspin      # log highlighter
  worktrunk     # work tool
)

BREW_CASKS=(
  ghostty                    # primary terminal emulator
  alacritty                  # secondary terminal emulator
  raycast                    # launcher
  ngrok                      # tunnel tool
  font-symbols-only-nerd-font # nerd font icons
)

# ── Homebrew taps ─────────────────────────────────────────────────────────────
BREW_TAPS=(
  cormacrelf/tap     # dark-notify
  dlvhdr/formulae   # diffnav
  felixkratz/formulae # borders (optional, not installed by default)
)

for tap in "${BREW_TAPS[@]}"; do
  if ! brew tap | grep -q "^${tap%%#*}" 2>/dev/null; then
    echo -e "  ${YELLOW}→${NC} tapping ${tap%%#*}..."
    brew tap "${tap%%#*}" || true
  fi
done

echo -e "${YELLOW}→${NC} Installing brew packages..."
for pkg in "${BREW_PKGS[@]}"; do
  if brew list "$pkg" &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} $pkg"
  else
    echo -e "  ${YELLOW}→${NC} $pkg"
    brew install "$pkg"
  fi
done

echo -e "${YELLOW}→${NC} Installing brew casks..."
for cask in "${BREW_CASKS[@]}"; do
  if brew list --cask "$cask" &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} $cask"
  else
    echo -e "  ${YELLOW}→${NC} $cask"
    brew install --cask "$cask" --force || true  # non-fatal: may already be installed via .dmg
  fi
done

# ── mise ──────────────────────────────────────────────────────────────────────
if ! command_exists mise; then
  echo -e "${YELLOW}→${NC} Installing mise..."
  curl https://mise.run | sh
  export PATH="$HOME/.local/share/mise/bin:$PATH"
fi
echo -e "${GREEN}✓${NC} mise installed"

echo -e "${YELLOW}→${NC} Running mise install (this may take a while)..."
mise install
echo -e "${GREEN}✓${NC} mise tools installed"

echo ""
echo -e "${GREEN}✓${NC} macOS bootstrap complete. Restart your terminal or run: exec zsh"
{{ end -}}
