# AWS Credentials - managed by chezmoi + 1Password
# OS-conditional: macOS and Linux sections are separate.
#
# --- macOS (darwin) ---
# 1Password item: "AWS Credentials" in vault "Private"
# Fields: default_key_id, default_secret, production_key_id, production_secret,
#         development_key_id, development_secret, torchmark_key_id, torchmark_secret,
#         personalcluster_key_id, personalcluster_secret, personalcluster_region,
#         jobnation_key_id, jobnation_secret
#
# --- Linux ---
# TODO: create a "AWS Credentials Linux" item in vault "Private" with fields:
#         linux_default_key_id, linux_default_secret
#         (add more profiles as needed)
# Then fill in the placeholders in the linux section below.

{{ if eq .chezmoi.os "darwin" -}}
[default]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/default_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/default_secret" }}

[production]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/production_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/production_secret" }}

[development]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/development_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/development_secret" }}

[torchmark]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/torchmark_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/torchmark_secret" }}

[personalcluster]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/personalcluster_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/personalcluster_secret" }}
region = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/personalcluster_region" }}

[jobnation-prod]
aws_access_key_id = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/jobnation_key_id" }}
aws_secret_access_key = {{ output "op" "read" "--no-newline" "op://Private/AWS Credentials/jobnation_secret" }}
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
# TODO: replace placeholders with real op:// references once Linux AWS keys are in 1Password
# Example:
# [default]
# aws_access_key_id = {{ "{{" }} onepasswordRead "op://Private/AWS Credentials Linux/linux_default_key_id" {{ "}}" }}
# aws_secret_access_key = {{ "{{" }} onepasswordRead "op://Private/AWS Credentials Linux/linux_default_secret" {{ "}}" }}
{{ end -}}
